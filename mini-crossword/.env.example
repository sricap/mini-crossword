# Supabase (required for DB save/load). Copy to .env and fill in.
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key

# --- AI clue hints (solver) — server-only on Vercel, NOT VITE_ ---
# Set in Vercel Project → Settings → Environment Variables (Production + Preview).
# GEMINI_API_KEY=your-google-ai-studio-key
# Optional: GEMINI_MODEL=gemini-2.0-flash
# Optional rate limits (defaults: 20 requests / 60s per IP per serverless instance):
# AI_HINT_RATE_LIMIT_MAX=20
# AI_HINT_RATE_LIMIT_WINDOW_MS=60000

# Local dev: optional origin for Vite proxy target if not using default 127.0.0.1:3000
# VITE_AI_HINT_ORIGIN=http://127.0.0.1:3000
